#!/usr/bin/env bash
# Run paumen-lint on staged files; block commit on violations.
# Enable in a repo with:  git config core.hooksPath .githooks
set -euo pipefail

mapfile -t staged < <(
  git diff --cached --name-only --diff-filter=ACM \
  | grep -E '\.(html?|jsx?|tsx?|mjs|css)$' || true
)

[ ${#staged[@]} -eq 0 ] && exit 0

exec "$(git rev-parse --show-toplevel)/scripts/paumen-lint.sh" "${staged[@]}"
